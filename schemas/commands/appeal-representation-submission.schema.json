{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "commands/appeal-representation-submission.schema.json",
	"title": "appeal-representation-submission",
	"description": "Schema defining a submission of a representation made by a party on an appeal",
	"type": "object",
	"additionalProperties": true,
    "required": [
        "representation",
        "documents"        
    ],
	"properties": {
        "representation": {
            "type": "object",
            "additionalProperties": true,
            "required": ["caseReference", "representationType", "submittedDate"],
            "properties": {
                "caseReference": {
                    "type": "string",
                    "examples": ["7002471"],
                    "description": "External case identifier"
                },
                "serviceUserId": {
                    "type": ["string", "null"],
                    "description": "Maps to [ServiceUser].[id], will be rule 6, agent or appellant"
                },
                "lpaCode": {
                    "type": ["string", "null"],
                    "examples": ["Q9999"],
                    "description": "A unique identifier for the Local Planning Authority",
                    "$comment": "Uses the internal PINS code identifying LPAs"
                },
                "newUser": {
                    "type": "object",
                    "additionalProperties": true,
                    "description": "Schema defining a new user to the appeal making a representation, currently only used for interested party comments",
                    "required": [],
                    "properties": {
                        "firstName": {
                            "type": "string",
                            "examples": ["Alan"]
                        },
                        "lastName": {
                            "type": "string",
                            "examples": ["Turing"]
                        },
                        "emailAddress": {
                            "type": ["string", "null"],
                            "examples": ["john.doe@example.com"]
                        },
                        "address": {
                            "title": "Address",
                            "type": "object",
                            "required": ["addressLine1", "town", "postcode"],
                            "properties": {
                                "addressLine1": {
                                    "type": "string",
                                    "examples": ["National Traffic Operations Centre"]
                                },
                                "addressLine2": {
                                    "type": "string",
                                    "examples": ["3 Ridgeway, Quinton Business Park"]
                                },
                                "town": {
                                    "type": "string",
                                    "examples": ["Birmingham"]
                                },
                                "county": {
                                    "type": ["string", "null"],
                                    "examples": ["Birmingham"]
                                },
                                "postcode": {
                                    "type": "string",
                                    "examples": ["B32 1AF"]
                                }
                            }
                        }
                    }
                },
                "representationType": {
                    "type": ["string", "null"],
                    "enum": ["statement", "comment", "final_comment", "proofs_evidence", null],
                    "description": "The type of representation"
                },
                "representation": {
                    "type": ["string", "null"],
                    "examples": ["I have concerns"]
                },
                "submittedDate": {
                    "type": ["string"],
                    "format": "date-time",
                    "examples": ["2023-07-27T20:30:00.000Z"],
                    "description": "The date the statement was submitted by the user"
                }
            },
            "oneOf": [
                { "required": ["serviceUserId"] },
                { "required": ["lpaCode"] },
                { "required": ["newUser"] }
            ]
        },
        "documents": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                    "documentId",
                    "filename",
                    "originalFilename",
                    "size",
                    "mime",
                    "documentURI",
                    "dateCreated",
                    "documentType"
                ],
                "properties": {
                    "documentId": {
                        "type": "string",
                        "examples": ["4547fec8-16b2-47bb-836d-4d0baac04079"],
                        "description": "The unique identifier for the document"
                    },
                    "filename": {
                        "type": "string",
                        "examples": ["filename.pdf"],
                        "description": "Current stored name of the document"
                    },
                    "originalFilename": {
                        "type": "string",
                        "examples": ["original_filename.pdf"],
                        "description": "Original name of document"
                    },
                    "size": {
                        "type": "integer",
                        "examples": [23452],
                        "description": "The file size, in bytes"
                    },
                    "mime": {
                        "type": ["string"],
                        "examples": ["application/pdf"],
                        "description": "The mime type for the current version of the file"
                    },
                    "documentURI": {
                        "type": "string",
                        "examples": [
                        "https://custom-domain.gov.uk/container-name/appeal/7002471/4547fec8-16b2-47bb-836d-4d0baac04079/v1/filename.pdf"
                        ],
                        "description": "The internal location of the document",
                        "$comment": "This property contains blob storage info (domain, container), caseReference, version and filename"
                    },
                    "dateCreated": {
                        "type": "string",
                        "format": "date-time",
                        "examples": ["2023-07-27T20:30:00.000Z"],
                        "description": "The creation date for the document"
                    },
                    "documentType": {
                        "type": ["string", "null"],
                        "enum": [
                            "appealStatement",
                            null
                        ],
                        "description": "The type of document, used for exchange, migrations and consumption from the appeal back-office system"
                    }
                }
            }
        }        
	}
}
