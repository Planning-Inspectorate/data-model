{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "commands/appeal-interested-party-comment.schema.json",
	"title": "appeal-interested-party-comment",
	"description": "Schema defining comments made by an interested party on an appeal",
	"type": "object",
	"additionalProperties": true,
	"required": ["caseReference", "firstName", "lastName", "comments" , "submittedDate"],
	"properties": {
        "caseReference": {
            "type": "string",
            "examples": ["7002471"],
            "description": "External case identifier"
        },
		"firstName": {
			"type": "string",
			"examples": ["Alan"]
		},
		"lastName": {
			"type": "string",
			"examples": ["Turing"]
		},
        "emailAddress": {
			"type": ["string", "null"],
            "examples": ["john.doe@example.com"]
		},
        "address": {
			"title": "Address",
			"type": "object",
			"required": ["addressLine1", "town", "postcode"],
			"properties": {
				"addressLine1": {
					"type": "string",
					"examples": ["National Traffic Operations Centre"]
				},
				"addressLine2": {
					"type": "string",
					"examples": ["3 Ridgeway, Quinton Business Park"]
				},
				"town": {
					"type": "string",
					"examples": ["Birmingham"]
				},
                "county": {
                    "type": ["string", "null"],
                    "examples": ["Birmingham"]
                },
				"postcode": {
					"type": "string",
					"examples": ["B32 1AF"]
				}
			}
		},
        "comments": {
            "type": ["string"],
            "examples": ["I have concerns"]
        },
        "submittedDate": {
            "type": "string",
            "format": "date-time",
            "examples": ["2023-07-27T20:30:00.000Z"],
            "description": "The date the comment was submitted by the interested party"
        }
	}
}
